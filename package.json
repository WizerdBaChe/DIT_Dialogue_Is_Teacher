{
  "name": "dit-dialogue-is-teacher",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "把 AI coding agent 的執行軌跡轉成可學習的結構化節點視圖",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && vite build --config vite.snapshot.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview",
    "fixture:r5": "node scripts/generate-r5-fixture.mjs",
    "benchmark:r5": "node scripts/render-r5-benchmark.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.6",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
}
